#######################################################################
# MEDIEVAL–JEWISH–PHILOSOPHY ONTOLOGY (JPO)
#######################################################################

@prefix jp: <http://jewish_philosophy.org/ontology#> .
@prefix schema: <http://schema.org/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

#######################################################################
# ONTOLOGY DECLARATION
#######################################################################

jp: a owl:Ontology ;
    rdfs:label "Medieval Jewish Philosophy Ontology (JPO)" ;
    dcterms:creator "YOUR NAME" ;
    dcterms:description "Ontology for historical Jewish philosophers, their works, and modern scholarly resources." ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> .

#######################################################################
# CLASSES
#######################################################################

jp:HistoricalPerson a owl:Class ;
    rdfs:label "Historical Person" ;
    rdfs:comment "A pre-modern person relevant to Jewish philosophy." .

jp:HistoricalWork a owl:Class ;
    rdfs:label "Historical Work" ;
    rdfs:comment "A primary historical or medieval text authored by a historical person." .


jp:Language a owl:Class ;
    rdfs:label "Language" ;
    rdfs:comment "A historical or classical language used in medieval Jewish texts." .

jp:Subject a owl:Class ;
    rdfs:label "Subject" ;
    rdfs:comment "A topical subject area of a work: astronomy, theology, philosophy, etc." .


jp:Place a owl:Class ;
    rdfs:label "Place" ;
    rdfs:comment "A geographic or historical location relevant to persons or works." .


jp:Source a owl:Class ;
    rdfs:label "Data Source" ;
    rdfs:comment "A scholarly project or data collection that provides the information about a historical person." .

#######################################################################
# TEMPORAL AND SPATIAL CLASSES
#######################################################################

jp:TimeRelation a owl:Class ;
    rdfs:label "Time Relation" ;
    rdfs:comment "A temporal assertion relating an entity to a time span, e.g., birth, death, activity." .

jp:Time a owl:Class ;
    rdfs:label "Time" ;
    rdfs:comment "The actual time data (years or dates) representing the specific time." .

jp:TimeBucket a owl:Class ;
    rdfs:label "Time Bucket" ;
    rdfs:comment "A standard 50-year interval used for grouping entities by their active/living periods." .

jp:PlaceRelation a owl:Class ;
    rdfs:label "Place Relation" ;
    rdfs:comment "A spatial assertion relating an entity to a place, e.g., birth, death, residence, travel." .

#######################################################################
# RELATION / OBJECT PROPERTIES
#######################################################################


jp:writtenBy a owl:ObjectProperty ;
    rdfs:label "written by" ;
    rdfs:domain jp:HistoricalWork ;
    rdfs:range jp:HistoricalPerson ;
    rdfs:comment "Indicates that a historical work was authored by a historical person." .





jp:hasSubject a owl:ObjectProperty ;
    rdfs:label "has subject" ;
    rdfs:domain [ owl:unionOf ( jp:HistoricalWork jp:HistoricalPerson ) ] ;
    rdfs:range jp:Subject ;
    rdfs:comment "Associates a historical work with its subject or topical classification." .






jp:hasTimeRelation a owl:ObjectProperty ;
    rdfs:label "has time relation" ;
    rdfs:domain jp:HistoricalPerson ;
    rdfs:range jp:TimeRelation ;
    rdfs:comment "Links an entity to a time assertion." .


jp:timeType a owl:DatatypeProperty ;
    rdfs:label "time type" ;
    rdfs:domain jp:TimeRelation ;
    rdfs:range xsd:string ;
    rdfs:comment "The kind of temporal relation, e.g., birth, death, activity." .

jp:hasTimeData a owl:ObjectProperty ;
    rdfs:label "has time data" ;
    rdfs:domain jp:TimeRelation ;
    rdfs:range jp:Time ;
    rdfs:comment "Links a time relation to the specific time data." .

jp:timeLabel a owl:DatatypeProperty ;
    rdfs:label "time label" ;
    rdfs:domain jp:Time ;
    rdfs:range xsd:string ;
    rdfs:comment "The exact string representation of the time from the source." .

jp:inTimeBucket a owl:ObjectProperty ;
    rdfs:label "in time bucket" ;
    rdfs:domain jp:TimeRelation ;
    rdfs:range jp:TimeBucket ;
    rdfs:comment "Links an entity or a time relation to a standard 50-year bucket." .

jp:hasPlaceRelation a owl:ObjectProperty ;
    rdfs:label "has place relation" ;
    rdfs:domain jp:HistoricalPerson ;
    rdfs:range jp:PlaceRelation ;
    rdfs:comment "Links an entity to a place assertion." .

jp:relatedPlace a owl:ObjectProperty ;
    rdfs:label "related place" ;
    rdfs:domain jp:PlaceRelation ;
    rdfs:range jp:Place ;
    rdfs:comment "The actual place associated with this relation (birth, death, residence, etc.)." .

jp:hasSource a owl:ObjectProperty ;
    rdfs:label "has source" ;
    rdfs:domain jp:HistoricalPerson ;
    rdfs:range jp:Source ;
    rdfs:comment "Associates a historical person with the data source (e.g. a scholarly project) it originates from." .

#######################################################################
# DATATYPE PROPERTIES
#######################################################################







jp:timeFrom a owl:DatatypeProperty ;
    rdfs:label "time from" ;
    rdfs:domain jp:Time ;
    rdfs:range xsd:gYear ;
    rdfs:comment "Start of the time interval (or single year)." .

jp:timeUntil a owl:DatatypeProperty ;
    rdfs:label "time until" ;
    rdfs:domain jp:Time ;
    rdfs:range xsd:gYear ;
    rdfs:comment "End of the time interval (or single year)." .

jp:bucketLabel a owl:DatatypeProperty ;
    rdfs:label "bucket label" ;
    rdfs:domain jp:TimeBucket ;
    rdfs:range xsd:string ;
    rdfs:comment "Label of the 50-year interval, e.g., 1150-1200." .

jp:placeType a owl:DatatypeProperty ;
    rdfs:label "place type" ;
    rdfs:domain jp:PlaceRelation ;
    rdfs:range xsd:string ;
    rdfs:comment "The kind of place relation, e.g., birth, death, residence, travel." .

jp:latitude a owl:DatatypeProperty ;
    rdfs:label "latitude" ;
    rdfs:domain jp:Place ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Latitude of a place (WGS84)." .

jp:longitude a owl:DatatypeProperty ;
    rdfs:label "longitude" ;
    rdfs:domain jp:Place ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Longitude of a place (WGS84)." .







#######################################################################
# SCHOLARLY METADATA CLASSES
#######################################################################



#######################################################################
# SCHOLARLY RELATIONS
#######################################################################





# Note: jp:publisher (string) is already defined.

#######################################################################
# END OF VOCABULARY
#######################################################################

jp:hasLanguage a owl:ObjectProperty ;
    rdfs:label "has language" ;
    rdfs:domain jp:HistoricalPerson ;
    rdfs:range jp:Language ;
    rdfs:comment "Associates a historical person with a language they spoke or wrote in." .

jp:latitude a owl:DatatypeProperty ;
    rdfs:label "latitude" ;
    rdfs:domain jp:Place ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Latitude coordinate of a place." .

jp:longitude a owl:DatatypeProperty ;
    rdfs:label "longitude" ;
    rdfs:domain jp:Place ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Longitude coordinate of a place." .

jp:bucketLabel a owl:DatatypeProperty ;
    rdfs:label "bucket label" ;
    rdfs:domain jp:TimeBucket ;
    rdfs:range xsd:string ;
    rdfs:comment "Label of the 50-year interval, e.g., 1150-1200." .

jp:placeType a owl:DatatypeProperty ;
    rdfs:label "place type" ;
    rdfs:domain jp:PlaceRelation ;
    rdfs:range xsd:string ;
    rdfs:comment "Type of place relation, e.g., birth, death, residence." .

jp:timeLabel a owl:DatatypeProperty ;
    rdfs:label "time label" ;
    rdfs:domain jp:TimeData ;
    rdfs:range xsd:string ;
    rdfs:comment "Human readable label for time." .

jp:timeType a owl:DatatypeProperty ;
    rdfs:label "time type" ;
    rdfs:domain jp:TimeRelation ;
    rdfs:range xsd:string ;
    rdfs:comment "Type of time relation, e.g., flourished, active." .

jp:timeFrom a owl:DatatypeProperty ;
    rdfs:label "time from" ;
    rdfs:domain jp:TimeData ;
    rdfs:range xsd:integer ;
    rdfs:comment "Start year." .

jp:timeUntil a owl:DatatypeProperty ;
    rdfs:label "time until" ;
    rdfs:domain jp:TimeData ;
    rdfs:range xsd:integer ;
    rdfs:comment "End year." .

jp:translated a owl:ObjectProperty ;
    rdfs:label "translated" ;
    rdfs:domain jp:HistoricalPerson ;
    rdfs:range jp:HistoricalPerson ;
    rdfs:comment "Indicates that this person translated the work of another person." .

jp:isTranslationOf a owl:ObjectProperty ;
    rdfs:label "is translation of" ;
    rdfs:domain jp:HistoricalWork ;
    rdfs:range jp:HistoricalWork ;
    rdfs:comment "Indicates that this work is a translation of another work." .

