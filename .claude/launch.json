{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Backend (Python)",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd backend && source ../venv/bin/activate && uvicorn app.main:app --host 127.0.0.1 --port 8000 --reload"],
      "port": 8000
    },
    {
      "name": "Frontend (React)",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd frontend && npm run dev"],
      "port": 5173
    }
  ]
}
